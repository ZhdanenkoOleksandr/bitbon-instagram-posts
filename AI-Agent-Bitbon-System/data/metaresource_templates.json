{
  "version": "1.0.0",
  "description": "Шаблоны для создания демо-метаресурсов",
  "templates": {
    "product": {
      "id": "tmpl_product",
      "name": "Товар",
      "icon": "📦",
      "description": "Физический товар (оборудование, материалы, продукция)",
      "fields": [
        {
          "id": "name",
          "label": "Название товара",
          "type": "text",
          "required": true,
          "placeholder": "Например: Промышленный станок XYZ-3000",
          "help": "Полное название товара"
        },
        {
          "id": "category",
          "label": "Категория",
          "type": "select",
          "required": true,
          "options": [
            "Оборудование",
            "Материалы",
            "Электроника",
            "Транспорт",
            "Недвижимость",
            "Другое"
          ]
        },
        {
          "id": "description",
          "label": "Описание",
          "type": "textarea",
          "required": true,
          "placeholder": "Подробное описание товара, характеристики, состояние...",
          "help": "Чем подробнее, тем выше доверие покупателей"
        },
        {
          "id": "price",
          "label": "Стоимость (BITBON)",
          "type": "number",
          "required": true,
          "min": 1,
          "placeholder": "1000",
          "help": "Рыночная стоимость в токенах BITBON"
        },
        {
          "id": "quantity",
          "label": "Количество единиц",
          "type": "number",
          "required": true,
          "min": 1,
          "default": 1
        },
        {
          "id": "location",
          "label": "Местонахождение",
          "type": "text",
          "required": false,
          "placeholder": "Киев, Украина"
        },
        {
          "id": "images",
          "label": "Фотографии",
          "type": "file",
          "required": false,
          "accept": "image/*",
          "multiple": true,
          "max": 5
        }
      ],
      "benefits": [
        "Быстрая продажа через экосистему Bitbon",
        "Верификация подлинности товара",
        "Защита от мошенничества",
        "Доступ к глобальному рынку"
      ]
    },
    "service": {
      "id": "tmpl_service",
      "name": "Услуга",
      "icon": "🛠️",
      "description": "Профессиональная услуга (консалтинг, разработка, обслуживание)",
      "fields": [
        {
          "id": "name",
          "label": "Название услуги",
          "type": "text",
          "required": true,
          "placeholder": "Например: Разработка веб-приложения"
        },
        {
          "id": "category",
          "label": "Категория",
          "type": "select",
          "required": true,
          "options": [
            "IT & Разработка",
            "Консалтинг",
            "Маркетинг",
            "Дизайн",
            "Образование",
            "Финансы",
            "Юридические услуги",
            "Другое"
          ]
        },
        {
          "id": "description",
          "label": "Что входит в услугу",
          "type": "textarea",
          "required": true,
          "placeholder": "• Анализ требований\n• Разработка архитектуры\n• Программирование\n• Тестирование\n• Запуск"
        },
        {
          "id": "price",
          "label": "Стоимость (BITBON)",
          "type": "number",
          "required": true,
          "min": 1,
          "placeholder": "5000"
        },
        {
          "id": "duration",
          "label": "Срок выполнения",
          "type": "text",
          "required": true,
          "placeholder": "30 дней"
        },
        {
          "id": "deliverables",
          "label": "Результаты работы",
          "type": "textarea",
          "required": true,
          "placeholder": "• Готовое веб-приложение\n• Исходный код\n• Документация\n• Обучение команды"
        }
      ],
      "benefits": [
        "Предоплата в токенах BITBON",
        "Прозрачные условия сотрудничества",
        "Автоматическое выполнение договоров",
        "Репутация подтверждается системой"
      ]
    },
    "real_estate": {
      "id": "tmpl_real_estate",
      "name": "Недвижимость",
      "icon": "🏢",
      "description": "Коммерческая или жилая недвижимость",
      "fields": [
        {
          "id": "name",
          "label": "Название объекта",
          "type": "text",
          "required": true,
          "placeholder": "Например: Офисное помещение 150м² в центре"
        },
        {
          "id": "type",
          "label": "Тип недвижимости",
          "type": "select",
          "required": true,
          "options": [
            "Офис",
            "Склад",
            "Торговая площадь",
            "Квартира",
            "Дом",
            "Земельный участок"
          ]
        },
        {
          "id": "area",
          "label": "Площадь (м²)",
          "type": "number",
          "required": true,
          "min": 1
        },
        {
          "id": "address",
          "label": "Адрес",
          "type": "text",
          "required": true,
          "placeholder": "ул. Крещатик, 1, Киев"
        },
        {
          "id": "price",
          "label": "Стоимость (BITBON)",
          "type": "number",
          "required": true,
          "min": 1
        },
        {
          "id": "description",
          "label": "Описание",
          "type": "textarea",
          "required": true,
          "placeholder": "Состояние, особенности, инфраструктура..."
        },
        {
          "id": "ownership",
          "label": "Документы на собственность",
          "type": "file",
          "required": true,
          "accept": ".pdf",
          "help": "Сканы документов подтверждающих права"
        }
      ],
      "benefits": [
        "Дробное владение (токенизация)",
        "Быстрая ликвидность",
        "Прозрачная история сделок",
        "Минимизация посредников"
      ]
    },
    "intellectual_property": {
      "id": "tmpl_ip",
      "name": "Интеллектуальная собственность",
      "icon": "💡",
      "description": "Патенты, авторские права, лицензии",
      "fields": [
        {
          "id": "name",
          "label": "Название",
          "type": "text",
          "required": true,
          "placeholder": "Патент на технологию X"
        },
        {
          "id": "type",
          "label": "Тип ИС",
          "type": "select",
          "required": true,
          "options": [
            "Патент",
            "Авторское право",
            "Торговая марка",
            "Ноу-хау",
            "Лицензия"
          ]
        },
        {
          "id": "description",
          "label": "Описание",
          "type": "textarea",
          "required": true
        },
        {
          "id": "price",
          "label": "Стоимость лицензии (BITBON)",
          "type": "number",
          "required": true
        },
        {
          "id": "exclusivity",
          "label": "Эксклюзивность",
          "type": "select",
          "required": true,
          "options": [
            "Эксклюзивная лицензия",
            "Неэксклюзивная лицензия",
            "Полная передача прав"
          ]
        }
      ],
      "benefits": [
        "Защита прав через блокчейн",
        "Автоматическое отслеживание использования",
        "Роялти в токенах BITBON",
        "Глобальная доступность"
      ]
    }
  },

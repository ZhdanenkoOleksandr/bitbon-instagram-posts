      },
      {
        "step": 4,
        "title": "Предпросмотр",
        "description": "Проверьте как выглядит ваш метаресурс",
        "action": "preview"
      },
      {
        "step": 5,
        "title": "Создание ДЕМО",
        "description": "Сгенерируйте тестовую версию для изучения",
        "action": "create_demo"
